# Sahayak Pay Roll — environment variables
# Copy to .env for local use, or set these in Vercel → Project → Settings →
# Environment Variables for a hosted deployment. NEVER commit the real .env.

# --- Email (fallback sender; each user can also set their own in the app) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
# 16-char Gmail App Password (https://myaccount.google.com/apppasswords)
EMAIL_PASSWORD=your-app-password
FROM_NAME=Accounts Department

# --- Supabase (login + saved profile/history/email settings) ---
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key (server-side only — never exposed to the browser)
SUPABASE_KEY=your-supabase-service-role-key

# Optional: shared secret for the /send endpoint (leave empty for normal use)
# RELAY_TOKEN=
